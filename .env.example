# ---- Fully-local stack (no external API) ----

# LLM: Qwen via Ollama (chat + classification + extraction + RAG)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b        # text model; reads PaddleOCR text (bump to qwen2.5:14b if VRAM allows)
OLLAMA_VISION_MODEL=qwen2.5vl:7b    # image-only / low-OCR docs when ENABLE_VISION=true

# Embeddings (RAG): local multilingual model
OLLAMA_EMBED_MODEL=bge-m3

# OCR engine (mandated) — documents are read with PaddleOCR, not a vision model
OCR_PROVIDER=paddle
PADDLE_LANG=en                      # en | ru | latin | cyrillic ...

# Vision: on by default so the multimodal model reads page images for
# classify/extract (more robust on bad PDF text layers). Set false for a
# pure text + PaddleOCR pipeline (then only OLLAMA_CHAT_MODEL is needed).
ENABLE_VISION=true
PREFER_VISION_EXTRACTION=true       # only applies when ENABLE_VISION=true

# Vector store (RAG)
QDRANT_URL=                         # e.g. http://localhost:6333 ; empty = embedded local
QDRANT_COLLECTION=customs_law

# App
APP_HOST=127.0.0.1
APP_PORT=8000
DEBUG=false
